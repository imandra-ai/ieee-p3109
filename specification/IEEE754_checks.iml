[@@@import IEEE754, "IEEE754.iml"]

open IEEE754
open CER

let smallest_nz_b32 = Util.pow2 (-149)
let largest_subnormal_b32 = Util.pow2 (-148)
let smallest_normal_b32 = Util.pow2 (-126)
let largest_normal_b32 = Util.pow2 127 *. (2.0 -. Util.pow2 (-23))

verify (List.length (round Format.Binary32 RoundingMode.TowardZero (R 2.0)) = 32) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R 0.0)) = Ok (CER.R 0.0)) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardNegative (R (- 1.0))) = Ok (CER.R (- 1.0))) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R 21.0)) = Ok (CER.R 21.0)) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R 0.125)) = Ok (CER.R (1.0 /. 8.0))) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R smallest_nz_b32)) =
        Ok (CER.R (1.0 /. 713623846352979940529142984724747568191373312.0))) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R largest_subnormal_b32)) =
        Ok (CER.R (1.0 /. 356811923176489970264571492362373784095686656.0))) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R smallest_normal_b32)) =
        Ok (CER.R (1.0 /. 85070591730234615865843651857942052864.0))) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R largest_normal_b32)) =
        Ok (CER.R 340282346638528859811704183484516925440.0)) [@@by auto]
verify (as_cer Format.Binary32 (pinf Format.Binary32) = Ok PInf) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero (R (largest_normal_b32 +. 1.0))) =
        Ok (CER.R 340282346638528859811704183484516925440.0)) [@@by auto]

let roundtrip32 (x : t) : (t, string) Result.t =
  (* convert extended real to IEEE754 single and back again *)
  as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardZero x)

verify (roundtrip32 (R 0.0) = Ok (R 0.0)) [@@by auto]
verify (roundtrip32 (R 1.0) = Ok (R 1.0)) [@@by auto]
verify (roundtrip32 (R (-1.0)) = Ok (R (-1.0))) [@@by auto]
verify (roundtrip32 (R 21.0) = Ok (R 21.0)) [@@by auto]
verify (roundtrip32 (R (- 21.0)) = Ok (R (- 21.0))) [@@by auto]
verify (roundtrip32 (R 0.125) = Ok (R 0.125)) [@@by auto]
verify (roundtrip32 PInf = Ok PInf) [@@by auto]
verify (roundtrip32 NInf = Ok NInf) [@@by auto]
verify (roundtrip32 (R smallest_nz_b32) = Ok (R smallest_nz_b32)) [@@by auto]
verify (roundtrip32 (R largest_subnormal_b32) = Ok (R largest_subnormal_b32)) [@@by auto]
verify (roundtrip32 (R smallest_normal_b32) = Ok (R smallest_normal_b32)) [@@by auto]
verify (roundtrip32 (R largest_normal_b32) = Ok (R largest_normal_b32)) [@@by auto]
verify (roundtrip32 (R (largest_normal_b32 *. 2.0)) = Ok PInf) [@@by auto]

(* -0.0 doesn't survive a tround-trip *)
verify (is_nzero (round Format.Binary32 RoundingMode.TowardNegative (R 0.0))) [@@by auto]
verify (as_cer Format.Binary32 (round Format.Binary32 RoundingMode.TowardNegative (R 0.0)) = Ok (R 0.0)) [@@by auto]

verify (encode (decode Format.Binary32 42) = 42) [@@by ground_eval ()]
verify (encode (decode Format.Binary32 21) = 21) [@@by ground_eval ()]
verify (encode (decode Format.Binary32 0) = 0) [@@by ground_eval ()]
verify (encode (decode Format.Binary32 65535) = 65535) [@@by ground_eval ()]

verify (encode (max_finite_t Format.Binary16) = 0x7BFF) [@@by ground_eval ()]
verify (encode (max_finite_t Format.Binary32) = 0x7F7FFFFF) [@@by ground_eval ()]
verify (encode (max_finite_t Format.Binary64) = 0x7FEFFFFFFFFFFFFF) [@@by ground_eval ()]
verify (encode (max_finite_t Format.Binary128) = 0x7FFEFFFFFFFFFFFFFFFFFFFFFFFFFFFF) [@@by ground_eval ()]