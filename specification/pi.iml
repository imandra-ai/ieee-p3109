[@@@import ErrorPropagation, "dune:basic"]
[@@@import Util, "dune:math"]

let ( ^. ) (x : real) (y : int) = Util.ripow x y

let pi (p : int) : real =
  (* A very slowly converging approximation of pi. *)
  let term (k : int) : real =
    2.0 /. Real.of_int ((4 * k + 1) * (4 * k + 3))
  in
  4.0 *. Util.sum (fun k _ -> term k) 0 p

let pi_half (p : int) : real =
  0.5 *. (pi p)

let pi_quarter (p : int) : real =
  0.25 *. (pi p)

theorem pi_half_is_half (p : int) =
  (pi_half p) [@trigger] = 0.5 *. pi p
  [@@fc]

theorem pi_quarter_is_quarter (p : int) =
  (pi_quarter p) [@trigger] = 0.25 *. pi p
  [@@fc]

theorem pi_quarter_is_half_of_of (p : int) =
  (pi_quarter p) [@trigger] = 0.5 *. pi_half p
  [@@fc]