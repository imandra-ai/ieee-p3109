[@@@import CER, "dune:math"]
[@@@import Util, "dune:math"]

(** IEEE 754 definitions for conversion functions *)

module RoundingMode = struct
  type t = TowardZero | TowardPositive | TowardNegative | TiesToAway | TiesToEven
end

module Format = struct
  type t = Binary16 | Binary32 | Binary64 | Binary128

  let parameters (phi : t) : int * int * int * int * int * int * int * real =
    (* Table 3.5 IEEE 754-2008 *)
    (* k, p, emax, bias, sign bit, w, t, max_finite *)
    let max_finite w emax = (2.0 -. Util.pow2 (- w)) *. Util.pow2 emax in
    match phi with
    | Binary16 -> 16, 11, 15, 15, 1, 5, 10, max_finite 10 15
    | Binary32 -> 32, 24, 127, 127, 1, 8, 23, max_finite 23 127
    | Binary64 -> 64, 53, 1023, 1023, 1, 11, 52, max_finite 52 1023
    | Binary128 -> 128, 113, 16383, 16383, 1, 15, 112, max_finite 112 16383

  let k (phi : t) = let k, _, _, _, _, _, _, _ = parameters phi in k [@@macro]
  let p (phi : t) = let _, p, _, _, _, _, _, _ = parameters phi in p [@@macro]
  let bias (phi : t) = let _, _, _, bias, _, _, _, _ = parameters phi in bias [@@macro]
  let max_finite (phi : t) = let _, _, _, _, _, _, _, m = parameters phi in m [@@macro]

  let to_string (phi : t) : string =
    match phi with
    | Binary16 -> "binary16"
    | Binary32 -> "binary32"
    | Binary64 -> "binary64"
    | Binary128 -> "binary128"
  [@@program]
end

type t = bool list

let rec nlist n e =
  match n with
  | x when x <= 0 -> []
  | _ -> [e] @ nlist (n-1) e

let nan (fmt : Format.t) : t =
  let _, _, _, _, _, w, t, _ = Format.parameters fmt in
  [false] @ nlist w true @ nlist (t - 1) false @ [true]

let quiet_nan (fmt : Format.t) : t = nan fmt

let canonical_nan (fmt : Format.t) : t = nan fmt

let inf (fmt : Format.t) (neg : bool) =
  let _, _, _, _, _, w, t, _ = Format.parameters fmt in
  let sgn = if neg then [true] else [false] in
  sgn @ nlist w true @ nlist t false

let pinf (fmt : Format.t) : t = inf fmt false

let ninf (fmt : Format.t) : t = inf fmt true

let pzero (fmt : Format.t) : t =
  let k, _, _, _, _, _, _, _ = Format.parameters fmt in
  nlist k false

let max_finite_t (fmt : Format.t) : t =
  let _, _, _, _, _, w, t, _ = Format.parameters fmt in
  [false] @ nlist (w - 1) true @ [false] @ nlist t true

let is_nan (fmt : Format.t) (x : t) : bool =
  let _, _, _, _, _, w, _, _ = Format.parameters fmt in
  let tail = List.tl x in
  let biased_exp = List.take w tail in
  let biased_exp_is_all_ones = not (List.mem false biased_exp) in
  let sig_bits = List.drop w tail in
  let sig_all_zero = not (List.mem true sig_bits) in
  biased_exp_is_all_ones && not sig_all_zero

let is_pinf (fmt : Format.t) (x : t) : bool = x = (pinf fmt)

let is_ninf (fmt : Format.t) (x : t) : bool = x = (ninf fmt)

let is_inf (fmt : Format.t) (x : t) : bool = x = (pinf fmt) || x = (ninf fmt)

let is_zero (x : t) : bool =
  match x with
  | [] -> true
  | _ :: xs -> not (List.mem true xs)

let is_pzero (x : t): bool =
  match x with
  | [] -> false
  | sgn :: _ -> is_zero x && sgn = false

let is_nzero (x : t) : bool =
  match x with
  | [] -> false
  | sgn :: _ -> is_zero x && sgn = true

let rec to_binary_bits (x : int) : bool list =
  let x = Int.abs x in
  if x = 0 then [] else
    to_binary_bits (x/2) @ [x mod 2 = 1]
  [@@measure (Ordinal.of_int (Int.abs x))]

let of_int_repr (phi: Format.t) (x : int) : t =
  if x < 0 || x >= Util.ipow2 (Format.k phi) then
    canonical_nan phi
  else
    let b = to_binary_bits x in
    if List.length b < Format.k phi then
      nlist (Format.k phi - List.length b) false @ b
    else if List.length b > Format.k phi then
      canonical_nan phi
    else
      b

let rec to_int_repr (x : t) : int =
  match x with
  | [] -> 0
  | true :: xs -> Util.ipow2 (List.length xs) + to_int_repr xs
  | false :: xs -> to_int_repr xs

let to_binary (x : int) (digits : int) : bool list =
  let r = to_binary_bits x in
  let lr = List.length r in
  if lr < digits then
    nlist (digits - lr) false @ r
  else
    r

let round_internal (fmt : Format.t) (rnd : RoundingMode.t) (x : CER.t) : (t,  string) Result.t =
  let open RoundingMode in
  let open CER in
  let open CER.ResultInfix in
  let _, _, emax, bias, _, w, t, _ = Format.parameters fmt in
  match x with
  | NaN -> Ok (nan fmt)
  | PInf -> Ok (pinf fmt)
  | NInf -> Ok (ninf fmt)
  | R r ->
    let is_neg = Real.(r < 0.0) || (r = 0.0 && rnd = RoundingMode.TowardNegative) in
    let sign = if is_neg then [true] else [false] in
    let r = Real.abs r in
    let is_subnormal = Real.(r < Util.pow2 Int.(1 - emax)) in
    let exp =
      if is_subnormal then
        Int.(1 - emax)
      else
        Util.floor_log2_abs r in
    let biased_exp =
      if is_subnormal then
        0
      else
        Int.(exp + bias) in
    let sigd = (r2a Real.(r / Util.pow2 exp)) * (2 ^ t) in
    (match sigd with
    | Ok (R sigd) ->
      if Int.(exp > emax) then
        Ok (inf fmt is_neg)
      else
        let sigd_trunc = Real.to_int sigd in
        let delta = Real.(sigd - Real.of_int sigd_trunc) in
        let rsig = (match rnd with
          | TowardZero -> sigd_trunc
          | TowardPositive when delta <> 0.0 && not is_neg -> Int.(sigd_trunc + 1)
          | TowardNegative when delta <> 0.0 && is_neg -> Int.(sigd_trunc + 1)
          | TiesToAway when delta = 0.5 -> sigd_trunc
          | TiesToEven when delta = 0.5 -> sigd_trunc
          | _ -> sigd_trunc) in
        let fsig = to_binary rsig t in
        Ok (sign @ to_binary biased_exp w @ List.tl fsig)
    | _ -> Error "invalid")

theorem round_internal_ok (fmt : Format.t) (rnd : RoundingMode.t) (x : CER.t)  =
  Result.is_ok (round_internal fmt rnd x)

let round (fmt : Format.t) (rnd : RoundingMode.t) (x : CER.t) : t =
  match round_internal fmt rnd x  with
  | Ok r -> r
  | Error _ -> nan fmt (* unreachable by theorem round_internal_ok *)

let rec from_binary (x : bool list) : int =
  match x with
  | [] -> 0
  | x :: xs ->
    (if x then Util.ipow2 (List.length xs) else 0) + (from_binary xs)

let biased_exponent (phi : Format.t) (x : t) : bool list =
  let _, _, _, _, _, w, _, _ = Format.parameters phi in
  List.take w (List.tl x)

let is_all_ones (xs : bool list) : bool = not (List.mem false xs)

let is_all_zeroes (xs : bool list) : bool = not (List.mem true xs)

let as_cer (phi : Format.t) (x : t) : (CER.t, string) Result.t =
  if is_nan phi x then
    Ok NaN
  else if is_pinf phi x then
    Ok PInf
  else if is_ninf phi x then
    Ok NInf
  else
    let _, _, _, bias, _, w, t, _ = Format.parameters phi in
    let sgn = if List.hd x = false then 1.0 else -1.0 in
    let tail = List.tl x in
    let biased_exp = biased_exponent phi x in
    let biased_exp_is_all_zeroes = is_all_zeroes biased_exp in
    let sig_bits = List.drop w tail in

    let sigd, exp =
      if biased_exp_is_all_zeroes then
        from_binary (false :: sig_bits),
        - bias + 1
      else
        from_binary (true :: sig_bits),
        from_binary biased_exp - bias
    in

    let open CER in
    let open CER.ResultInfix in
    ((r2a sgn) * (2 ^ exp)) ** ((i2a sigd) / (2 ^ t))

let bd acc b = acc ^ if b then "1" else "0"

let pp (x : t)  =
  List.fold_left bd "" x
