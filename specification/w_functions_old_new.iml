[@@@import Util, "dune:math"]
[@@@import CER, "dune:math"]
[@@@import Sqrt, "dune:math"]
[@@@import Exp, "dune:math"]
[@@@import Log, "dune:math"]
[@@@import Pi, "dune:math"]
[@@@import Trigonometric, "dune:math"]
[@@@import ErrorPropagation, "dune:basic"]
[@@@import IEEE754, "IEEE754.iml"]
[@@@import Theorems_pow2, "theorems_pow2.iml"]
[@@@import Specification, "specification.iml"]

(*
  References for all omega functions. The *_ref functions have the semantics we
  want and we can use the theorems in this file after making changes to the
  actual spec, to make sure we only change the things we want to change.
*)

open ErrorPropagation
open Specification
open Float

  let wRoundToPrecision_ref (p : int) (b : int) (rnd : RoundingMode.t) (x : CER.t) : CER.t =
    match internal_wRoundToPrecision p b rnd x with
    | Ok r -> r
    | Error _ -> R 0.0 (* unreachable by internal_round_to_precision_ok *)

theorem wRoundToPrecision_old_ref_eq (p : int) (b : int) (rnd : RoundingMode.t) (x : CER.t) =
  Float.wRoundToPrecision p b rnd x = wRoundToPrecision_ref p b rnd x

  let internal_wSaturate_ref
    (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t)
    (x : CER.t) (sigma : Signedness.t) (delta : Domain.t)
    : (CER.t, string) Result.t =
    let open RoundingMode in
    let open SaturationMode in
    let open Signedness in
    let open Domain in
    let m_lo =
      match sigma with
      | Signed -> -. m
      | Unsigned -> 0.0
      [@@ocaml.doc "nolatex"]
    in
    let m_hi = m [@@ocaml.doc "nolatex"] in
    match sat, rnd, x, sigma, delta with
    | _, _, NaN, _, _ -> Ok NaN

    | _, _, R x, _, _ when m_lo <=. x && x <=. m_hi -> Ok (R x)
    [@ocaml.doc "latex: \\\\"]

    | SatFinite, _, PInf, _, _ -> Ok (R m_hi)
    | SatFinite, _, NInf, _, _ -> Ok (R m_lo)
    | SatFinite, _, R x, _, _ when x <. m_lo -> Ok (R m_lo)
    | SatFinite, _, R x, _, _ when x >. m_hi -> Ok (R m_hi)
    [@ocaml.doc "latex: \\\\"]

    | SatPropagate, _, PInf, _, Extended -> Ok PInf
    | SatPropagate, _, PInf, _, _ -> Ok (R m_hi)
    | SatPropagate, _, NInf, Signed, Extended -> Ok NInf
    | SatPropagate, _, NInf, _, _ -> Ok (R m_lo)
    | SatPropagate, _, R x, _, _ when x <. m_lo -> Ok (R m_lo)
    | SatPropagate, _, R x, _, _ when x >. m_hi -> Ok (R m_hi)
    [@ocaml.doc "latex: \\\\"]

    (* Version before the finite-domain-nans change with the four new NaNs *)
    | SatNone, _, PInf, _, Extended -> Ok PInf
    | SatNone, _, PInf, _, _ -> Ok NaN (* NEW *)
    | SatNone, _, NInf, Signed, Extended -> Ok NInf
    | SatNone, _, NInf, Unsigned, _ -> Ok NaN
    | SatNone, _, NInf, _, _ -> Ok NaN (* NEW *)
    | SatNone, ToOdd, R x, Unsigned, Extended when x >. m_hi -> Ok (R m_hi)
    | SatNone, (TowardZero | TowardNegative), R x, _, _ when x >. m_hi -> Ok (R m_hi)
    | SatNone, (TowardZero | TowardPositive), R x, _, _ when x <. m_lo -> Ok (R m_lo)
    | SatNone, _, R x, Signed, Extended when x <. m_lo -> Ok NInf
    | SatNone, _, R x, Unsigned, _ when x <. m_lo -> Ok NaN
    | SatNone, _, R x, _, _ when x <. m_lo -> Ok NaN (* NEW *)
    | SatNone, _, R x, _, Extended when x >. m_hi -> Ok PInf
    | SatNone, _, R x, _, _ when x >. m_hi -> Ok NaN (* NEW *)

    | _ -> Error "unreachable"

theorem internal_wSaturate_old_ref_eq (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t) (x : CER.t) (s : Signedness.t) (d : Domain.t) =
  Float.internal_wSaturate m sat rnd x s d = internal_wSaturate_ref m sat rnd x s d

  let wSaturate_ref (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t) (x : CER.t) (s : Signedness.t) (d : Domain.t) : CER.t =
    match internal_wSaturate m sat rnd x s d with
    | Ok x -> x
    | Error _ -> R 0.0 (* unreachable by theorem internal_wSaturate_ok *)

theorem wSaturate_old_ref_eq (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t) (x : CER.t) (s : Signedness.t) (d : Domain.t) =
  Float.wSaturate m sat rnd x s d = wSaturate_ref m sat rnd x s d


  let wProject_ref (f : Format.t) (rho : Projection.t) (x : CER.t) : (t, string) Result.t =
    let sigma = signednessOf f in
    let delta = domainOf f in
    let* maxFinite =
      match wDecode f (maxFiniteOf f) with
      | CER.R v -> Ok v
      | _ -> Error "maxFinite not finite" (* unreachable by theorem maxFinite_is_finite *)
    in
    let r : CER.t = wRoundToPrecision_ref (precisionOf f) (exponentBiasOf f) (roundOf rho) x in
    let s : CER.t = wSaturate_ref maxFinite (satOf rho) (roundOf rho) r sigma delta in
    wEncode f s

theorem wProject_old_ref_eq (f : Format.t) (rho : Projection.t) (x : CER.t) =
  Float.wProject f rho x = wProject_ref f rho x

  let wConvert_ref (x : CER.t) : (CER.t, string) Result.t = Ok x

theorem wConvert_old_ref_eq (x : CER.t) =
  Float.wConvert x = wConvert_ref x

  let wAbs_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x with
    | NaN -> Ok NaN
    | NInf -> Ok PInf
    | PInf -> Ok PInf
    | R x -> Ok (R (Real.abs x))
    | _ -> Error "undefined"

theorem wAbs_old_ref_eq (x : CER.t) =
  Float.wAbs x = wAbs_ref x

  let wNegate_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x with
    | NaN -> Ok NaN
    | NInf -> Ok PInf
    | PInf -> Ok NInf
    | R x -> Ok (R (-. x))
    | _ -> Error "undefined"

theorem wNegate_old_ref_eq (x : CER.t) =
  Float.wNegate x = wNegate_ref x

  let wCopySign_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | (PInf | NInf), PInf -> Ok PInf
    | (PInf | NInf), NInf -> Ok NInf
    | (PInf | NInf), R y when y >=. 0.0 -> Ok PInf
    | (PInf | NInf), R y when y <. 0.0 -> Ok NInf
    | R x,  PInf  -> Ok (R (Real.abs x))
    | R x,  NInf -> Ok (R (-. (Real.abs x)))
    | R x,  R y when y >=. 0.0 -> Ok (R (Real.abs x))
    | R x,  R y when y <. 0.0 -> Ok (R (-. (Real.abs x)))
    | _ -> Error "undefined"

theorem wCopySign_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wCopySign x y = wCopySign_ref x y

  let wAdd_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, NInf -> Ok NaN
    | NInf, PInf -> Ok NaN
    | PInf, _ -> Ok PInf
    | _, PInf -> Ok PInf
    | NInf, _ -> Ok NInf
    |  _, NInf -> Ok NInf
    | R x, R y -> Ok (R (x +. y))
    | _ -> Error "undefined"

theorem wAdd_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wAdd x y = wAdd_ref x y

  let wSubtract_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, PInf -> Ok NaN
    | NInf, NInf -> Ok NaN
    | _, PInf -> Ok NInf
    | PInf, _ -> Ok PInf
    | _, NInf -> Ok PInf
    | NInf, _ -> Ok NInf
    | R x, R y -> Ok (R (x -. y))
    | _ -> Error "undefined"

theorem wSubtract_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wSubtract x y = wSubtract_ref x y

  let wMultiply_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, PInf -> Ok PInf
    | NInf, NInf -> Ok PInf
    | NInf, PInf -> Ok NInf
    | PInf, NInf -> Ok NInf
    | PInf, R y when y >. 0.0 -> Ok PInf
    | PInf, R y when y = 0.0 -> Ok NaN
    | PInf, R y when y <. 0.0 -> Ok NInf
    | R x, PInf when x >. 0.0 -> Ok PInf
    | R x, PInf when x = 0.0 -> Ok NaN
    | R x, PInf when x <. 0.0 -> Ok NInf
    | NInf, R y when y >. 0.0 -> Ok NInf
    | NInf, R y when y = 0.0 -> Ok NaN
    | NInf, R y when y <. 0.0 -> Ok PInf
    | R x, NInf when x >. 0.0 -> Ok NInf
    | R x, NInf when x = 0.0 -> Ok NaN
    | R x, NInf when x <. 0.0 -> Ok PInf
    | R x, R y -> Ok (R (x *. y))
    | _ -> Error "undefined"

theorem wMultiply_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMultiply x y = wMultiply_ref x y

  let wDivide_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, (PInf | NInf) -> Ok NaN
    | NInf, (PInf | NInf) -> Ok NaN
    | _, R 0.0 -> Ok NaN
    | PInf, R y when y >. 0.0 -> Ok PInf
    | PInf, R y when y <. 0.0 -> Ok NInf
    | NInf, R y when y >. 0.0 -> Ok NInf
    | NInf, R y when y <. 0.0 -> Ok PInf
    | _, (PInf | NInf) -> Ok (R 0.0)
    | R x, R y -> Ok (R (x /. y))
    | _ -> Error "undefined"

theorem wDivide_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wDivide x y = wDivide_ref x y

  let wFMA_ref (x : CER.t) (y : CER.t) (z : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y, z with
    | NaN, _ , _ -> Ok NaN
    | _ , NaN, _ -> Ok NaN
    | _ , _, NaN -> Ok NaN

    | R 0.0, (PInf | NInf), _ -> Ok NaN
    | (PInf | NInf), R 0.0, _ -> Ok NaN

    | R x, PInf, PInf when x <. 0.0 -> Ok NaN
    | R x, NInf, PInf when x >. 0.0 -> Ok NaN
    | PInf, R y, PInf when y <. 0.0 -> Ok NaN
    | NInf, R y, PInf when y >. 0.0 -> Ok NaN

    | R x, NInf, NInf when x <. 0.0 -> Ok NaN
    | R x, PInf, NInf when x >. 0.0 -> Ok NaN
    | NInf, R y, NInf when y <. 0.0 -> Ok NaN
    | PInf, R y, NInf when y >. 0.0 -> Ok NaN

    | NInf, PInf, PInf -> Ok NaN
    | PInf, NInf, PInf -> Ok NaN
    | PInf, PInf, NInf -> Ok NaN
    | NInf, NInf, NInf -> Ok NaN

    | PInf, PInf, _ -> Ok PInf
    | NInf, NInf, _ -> Ok PInf
    | PInf, NInf, _ -> Ok NInf
    | NInf, PInf, _ -> Ok NInf

    | _, _, PInf -> Ok PInf
    | _, _, NInf -> Ok NInf

    | R x, NInf, _ when x >. 0.0 -> Ok NInf
    | R x, NInf, _ when x <. 0.0 -> Ok PInf

    | R x, PInf, _ when x >. 0.0 -> Ok PInf
    | R x, PInf, _ when x <. 0.0 -> Ok NInf

    | PInf, R y, _ when y >. 0.0 -> Ok PInf
    | PInf, R y, _ when y <. 0.0 -> Ok NInf

    | NInf, R y, _ when y >. 0.0 -> Ok NInf
    | NInf, R y, _ when y <. 0.0 -> Ok PInf

    | R x, R y, R z -> Ok (R (x *. y +. z))

    | _ -> Error "undefined"

theorem wFMA_old_ref_eq (x : CER.t) (y : CER.t) (z : CER.t) =
  Float.wFMA x y z = wFMA_ref x y z

  let wFAA_ref (x : CER.t) (y : CER.t) (z : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y, z with
    | NaN, _ , _ -> Ok NaN
    | _ , NaN, _ -> Ok NaN
    | _ , _, NaN -> Ok NaN
    | PInf, NInf, _ -> Ok NaN
    | NInf, PInf, _ -> Ok NaN
    | PInf, _, NInf -> Ok NaN
    | NInf, _, PInf -> Ok NaN
    | _, PInf, NInf -> Ok NaN
    | _, NInf, PInf -> Ok NaN
    | PInf, PInf, PInf -> Ok PInf
    | NInf, NInf, NInf -> Ok NInf
    | _, PInf, PInf -> Ok PInf
    | PInf, _, PInf -> Ok PInf
    | PInf, PInf, _ -> Ok PInf
    | _, NInf, NInf -> Ok NInf
    | NInf, _, NInf -> Ok NInf
    | NInf, NInf, _ -> Ok NInf
    | PInf, _, _ -> Ok PInf
    | _, PInf, _ -> Ok PInf
    | _, _, PInf -> Ok PInf
    | NInf, _, _ -> Ok NInf
    | _, NInf, _ -> Ok NInf
    | _, _, NInf -> Ok NInf
    | R x, R y, R z -> Ok (R (x +. y +. z))
    | _ -> Error "undefined"

theorem wFAA_old_ref_eq (x : CER.t) (y : CER.t) (z : CER.t) =
  Float.wFAA x y z = wFAA_ref x y z

  let wSqrt_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x with
    | NaN -> Ok NaN
    | NInf -> Ok NaN
    | R x when x <. 0.0 -> Ok NaN
    | PInf -> Ok PInf
    | R x ->
      (match Sqrt.sqrt x CERR.approx with
      | Ok r -> Ok (R r)
      | Error e -> Error e)
    | _ -> Error "undefined"

theorem wSqrt_old_ref_eq (x : CER.t) =
  Float.wSqrt x = wSqrt_ref x

  let wRSqrt_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x with
    | NaN -> Ok NaN
    | NInf -> Ok NaN
    | R x when x <=. 0.0 -> Ok NaN
    | PInf -> Ok (R 0.0)
    | R x ->
      (match Util.reciprocal (Sqrt.sqrt x CERR.approx) with
      | Ok r -> Ok (R r)
      | Error e -> Error e)
    | _ -> Error "undefined"

theorem wRSqrt_old_ref_eq (x : CER.t) =
  Float.wRSqrt x = wRSqrt_ref x
  [@@disable Sqrt.sqrt]
  [@@by auto]

  let wExp_ref (x : CER.t) : (CER.t, string) Result.t =
    match x with
    | NaN -> Ok NaN
    | PInf -> Ok PInf
    | NInf -> Ok (R 0.0)
    | R x -> Ok (R (Exp.exp x CERR.approx))
    | _ -> Error "undefined"

theorem wExp_old_ref_eq (x : CER.t) =
  Float.wExp x = wExp_ref x

  let wLog_ref (x : CER.t) : (CER.t, string) Result.t =
    match x with
    | NaN -> Ok NaN
    | NInf -> Ok NaN
    | PInf -> Ok PInf
    | R x when x <. 0.0 -> Ok NaN
    | R 0.0 -> Ok NInf
    | R x -> (
      match Log.ln x CERR.approx with
      | Ok r -> Ok (R r)
      | Error e -> Error e)
    | _ -> Error "undefined"

theorem wLog_old_ref_eq (x : CER.t) =
  Float.wLog x = wLog_ref x

  let wExp2_ref (x : CER.t) : (CER.t, string) Result.t =
    match x with
    | NaN -> Ok NaN
    | PInf -> Ok PInf
    | NInf -> Ok (R 0.0)
    | R x -> (
      match Exp.exp2 x CERR.approx with
      | Ok r -> Ok (R r)
      | Error e -> Error e)
    | _ -> Error "undefined"

theorem wExp2_old_ref_eq (x : CER.t) =
  Float.wExp2 x = wExp2_ref x

  let wLog2_ref (x : CER.t) : (CER.t, string) Result.t =
    match x with
    | NaN -> Ok NaN
    | NInf -> Ok NaN
    | PInf -> Ok PInf
    | R x when x <. 0.0 -> Ok NaN
    | R 0.0 -> Ok NInf
    | R x -> (
      match Log.log2 x CERR.approx with
      | Ok r -> Ok (R r)
      | Error e -> Error e)
    | _ -> Error "undefined"

theorem wLog2_old_ref_eq (x : CER.t) =
  Float.wLog2 x = wLog2_ref x

  let wRecip_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x with
    | NaN -> Ok NaN
    | R 0.0 -> Ok NaN
    | (PInf | NInf) -> Ok (R 0.0)
    | R x -> Ok (R (1.0 /. x))
    | _ -> Error "undefined"

theorem wRecip_old_ref_eq (x : CER.t) =
  Float.wRecip x = wRecip_ref x

  let wHypot_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | _, (PInf | NInf) -> Ok PInf
    | (PInf | NInf), _ -> Ok PInf
    | R x, R y ->
      (match Sqrt.sqrt ((Util.ripow (Real.abs x) 2) +. (Util.ripow (Real.abs y) 2)) CERR.approx with
      | Ok r -> Ok (R r)
      | Error e -> Error e)
    | _ -> Error "undefined"

theorem wHypot_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wHypot x y = wHypot_ref x y

  let wArcTan2_ref (y : CER.t) (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    let open Trigonometric in
    match y, x with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | R 0.0, R 0.0 -> Ok NaN
    | NInf, (PInf | NInf) -> Ok NaN
    | PInf, (PInf | NInf) -> Ok NaN
    | _, PInf -> Ok (R 0.0)
    | R 0.0, R x when x >. 0.0 -> Ok (R 0.0)
    | PInf, _ -> Ok (R (Pi.pi_half CERR.approx))
    | R y, R 0.0 when y >. 0.0 -> Ok (R (Pi.pi_half CERR.approx))
    | _, NInf -> Ok (R (Pi.pi CERR.approx))
    | R 0.0, R x when x <. 0.0 -> Ok (R (Pi.pi CERR.approx))
    | NInf, _ -> Ok (R (-. (Pi.pi_half CERR.approx)))
    | R y, R 0.0 when y <. 0.0 -> Ok (R (-. (Pi.pi_half CERR.approx)))
    | R y, R x when x >. 0.0 -> Ok (R (Trigonometric.arctan (y /. x) CERR.approx))
    | R y, R x when y >. 0.0 && x <. 0.0 -> Ok (R ((Trigonometric.arctan (y /. x) CERR.approx) +. (Pi.pi CERR.approx)))
    | R y, R x when y <. 0.0 && x <. 0.0 -> Ok (R ((Trigonometric.arctan (y /. x) CERR.approx) -. (Pi.pi CERR.approx)))
    | _ -> Error "undefined"

theorem wArcTan2_old_ref_eq (y : CER.t) (x : CER.t) =
  Float.wArcTan2 y x = wArcTan2_ref y x

  let wArcTan2Pi_ref (y : CER.t) (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    let open Trigonometric in
    match y, x with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | R 0.0, R 0.0 -> Ok NaN
    | NInf, (PInf | NInf) -> Ok NaN
    | PInf, (PInf | NInf) -> Ok NaN
    | _, PInf -> Ok (R 0.0)
    | R 0.0, R x when x >. 0.0 -> Ok (R 0.0)
    | PInf, _ -> Ok (R (1.0 /. 2.0))
    | R y, R 0.0 when y >. 0.0 -> Ok (R (1.0 /. 2.0))
    | _, NInf -> Ok (R 1.0)
    | R 0.0, R x when x <. 0.0 -> Ok (R 1.0)
    | NInf, _ -> Ok (R (-. 1.0 /. 2.0))
    | R y, R 0.0 when y <. 0.0 -> Ok (R (-. 1.0 /. 2.0))
    | R y, R x when x >. 0.0 -> Ok (R ((Trigonometric.arctan (y /. x) CERR.approx) /. Pi.pi CERR.approx))
    | R y, R x when y >. 0.0 && x <. 0.0 -> Ok (R (((Trigonometric.arctan (y /. x) CERR.approx) +. (Pi.pi CERR.approx)) /. Pi.pi CERR.approx))
    | R y, R x when y <. 0.0 && x <. 0.0 -> Ok (R (((Trigonometric.arctan (y /. x) CERR.approx) -. (Pi.pi CERR.approx)) /. Pi.pi CERR.approx))
    | _ -> Error "undefined"

theorem wArcTan2Pi_old_ref_eq (y : CER.t) (x : CER.t) =
  Float.wArcTan2Pi y x = wArcTan2Pi_ref y x

  let wMinimum_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, PInf -> Ok PInf
    | NInf, NInf -> Ok NInf
    | PInf, NInf -> Ok NInf
    | NInf, PInf -> Ok NInf
    | PInf, R y -> Ok (R y)
    | R x, PInf -> Ok (R x)
    | NInf, _ -> Ok NInf
    | _, NInf -> Ok NInf
    | R x, R y -> Ok (if x <. y then (R x) else (R y))
    | _ -> Error "undefined"

theorem wMinimum_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMinimum x y = wMinimum_ref x y

  let wMaximum_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, PInf -> Ok PInf
    | NInf, NInf -> Ok NInf
    | PInf, NInf -> Ok PInf
    | NInf, PInf -> Ok PInf
    | PInf, _ -> Ok PInf
    | _, PInf -> Ok PInf
    | NInf, R y -> Ok (R y)
    | R x, NInf -> Ok (R x)
    | R x, R y -> Ok (if x <. y then (R y) else (R x))
    | _ -> Error "undefined"

theorem wMaximum_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMaximum x y = wMaximum_ref x y

  let wMinimumNumber_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, NaN -> Ok NaN
    | x, NaN -> Ok x
    | NaN, y -> Ok y
    | x, y -> wMinimum_ref x y
    | _ -> Error "undefined"

theorem wMinimumNumber_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMinimumNumber x y = wMinimumNumber_ref x y

  let wMaximumNumber_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, NaN -> Ok NaN
    | x, NaN -> Ok x
    | NaN, y -> Ok y
    | x, y -> wMaximum_ref x y
    | _ -> Error "undefined"

theorem wMaximumNumber_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMaximumNumber x y = wMaximumNumber_ref x y

  let wMinimumMagnitude_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, PInf -> Ok PInf
    | NInf, NInf -> Ok NInf
    | PInf, NInf -> Ok NInf
    | NInf, PInf -> Ok NInf
    | (PInf | NInf), R y  -> Ok (R y)
    | R x, (PInf | NInf)  -> Ok (R x)
    | R x, R y when Real.abs x <. Real.abs y -> Ok (R x)
    | R x, R y when Real.abs x >. Real.abs y -> Ok (R y)
    | R x, R y when Real.abs x = Real.abs y -> Ok (if x <. y then (R x) else (R y)) [@ocaml.text "breakindent"]
    | _ -> Error "undefined"

theorem wMinimumMagnitude_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMinimumMagnitude x y = wMinimumMagnitude_ref x y

  let wMaximumMagnitude_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok NaN
    | _, NaN -> Ok NaN
    | PInf, _ -> Ok PInf
    | _, PInf -> Ok PInf
    | NInf, _ -> Ok NInf
    | _, NInf  -> Ok NInf
    | R x, R y when Real.abs x >. Real.abs y -> Ok (R x)
    | R x, R y when Real.abs x <. Real.abs y -> Ok (R y)
    | R x, R y when Real.abs x = Real.abs y -> Ok (if x <. y then (R y) else (R x)) [@ocaml.text "breakindent"]
    | _ -> Error "undefined"

theorem wMaximumMagnitude_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMaximumMagnitude x y = wMaximumMagnitude_ref x y

  let wMinimumMagnitudeNumber_ref (x : CER.t) (y : CER.t) : (CER.t, string) Result.t =
    let open CER in
    match x, y with
    | NaN, _ -> Ok x
    | _, NaN -> Ok y
    | _, _ -> wMinimumMagnitude_ref x y

theorem wMinimumMagnitudeNumber_old_ref_eq (x : CER.t) (y : CER.t) =
  Float.wMinimumMagnitudeNumber x y = wMinimumMagnitudeNumber_ref x y

