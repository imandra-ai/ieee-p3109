  let wBlockDecode_ref (b : int) (f_s : Format.t) (f_x : Format.t) (s, x : t * t list) : (CER.t list, string) Result.t =
    if b < 1 || b <> List.length x then
      Error "invalid block size"
    else
      let@ cz = map_wMultiply f_s f_x s x in
      Ok cz

theorem wBlockDecode_old_ref_eq (b : int) (f_s : Format.t) (f_x : Format.t) (s, x : t * t list) =
  Float.wBlockDecode b f_s f_x (s, x) = wBlockDecode_ref b f_s f_x (s, x)

  let wBlockProject_ref
    (b : int)
    (f_s : Format.t) (f_r : Format.t) (rho_z : Projection.t)
    (s, x : t * CER.t list) :
    (t list, string) Result.t =
    if b < 0 || b <> List.length x then
      Error "invalid block size"
    else
      let open CER in
      let cs = wDecode f_s s in
      let@ cz = wBlockProject_map_cz cs x in
      let@ z = map_project f_r rho_z cz in
      Ok z

theorem wBlockProject_old_ref_eq (b : int) (f_s : Format.t) (f_r : Format.t) (rho_z : Projection.t) (s, x : t * CER.t list) =
  Float.wBlockProject b f_s f_r rho_z (s, x) = wBlockProject_ref b f_s f_r rho_z (s, x)
[@@by unroll 20]

  let wExpMinusOne_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in

    let wExp_ref xr =
      (* A helper to squelch the error handling *)
      match wExp_ref xr with
      | Ok r -> r
      | Error _ -> CER.zero (* unreachable by theorem wExp_ok *)
      [@@ocaml.doc "nolatex"]
    in

    match x with
    | x -> wSubtract_ref (wExp_ref x) (R 1.0)
    | _ -> Error "undefined"

theorem wExpMinusOne_old_ref_eq (x : CER.t) =
  Float.wExpMinusOne x = wExpMinusOne_ref x

  let wLogOnePlus_ref (x : CER.t) : (CER.t, string) Result.t =
    let open CER in
    let wLog_ref xr =
      (* A helper to squelch the error handling *)
      match xr with
      | Ok r -> wLog_ref r
      | Error _ -> Ok CER.zero (* unreachable by theorem wLog_ok *)
      [@@ocaml.doc "nolatex"]
    in
    match x with
    | x -> wLog_ref (wAdd_ref (R 1.0) x)
    | _ -> Error "undefined"

