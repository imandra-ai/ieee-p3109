let isNormalOld (f : Format.t) (x : Float.t) : bool =
  let open Float in
  let open Signedness in
  let k = bitwidthOf f in
  let p = precisionOf f in
  match x with
  | _ when isZero f x || is_ninf f x || is_pinf f x || is_nan f x -> false
  | _ ->
    let x = to_int_repr f x in
    (match (signednessOf f) with
    | Signed -> Util.machine_idiv (x mod (Util.ipow2 (k - 1))) (Util.ipow2 (p - 1)) > 0
    | Unsigned -> Util.machine_idiv x (Util.ipow2 (p - 1)) > 0)

theorem isNormalChecks (f : Format.t) =
  Float.bitwidthOf f >= 3 &&
  (not (Float.signednessOf f = Signedness.Signed && Float.bitwidthOf f = Float.precisionOf f))
  ==>
  Float.isNormal f (Float.nan f) = isNormalOld f (Float.nan f) &&
  (match (Float.pinf f) with
  | Ok pinf -> Float.isNormal f pinf  = isNormalOld f pinf
  | _ -> true) &&
  (match (Float.ninf f) with
  | Ok ninf -> Float.isNormal f ninf  = isNormalOld f ninf
  | _ -> true) &&
  Float.isNormal f Float.zero = isNormalOld f Float.zero
  &&
  (match (Float.wEncode f (CER.R 1.0)) with
  | Ok one -> Float.isNormal f one = isNormalOld f one
  | _ -> true)
  &&
  (match (Float.wEncode f (CER.R (- 1.0))) with
  | Ok mone -> Float.isNormal f mone = isNormalOld f mone
  | _ -> true)
  &&
  let mn = Float.minNormalOf f in
  Float.isNormal f mn = isNormalOld f mn
  &&
  let mn = Float.minNormalOf f - 1 in
  Float.isNormal f mn = isNormalOld f mn
  &&
  let mn = Float.minNormalOf f + 1 in
  Float.isNormal f mn = isNormalOld f mn
  &&
  let mn = Float.maxFiniteOf f in
  Float.isNormal f mn = isNormalOld f mn
  [@@timeout 3600]
  [@@by enumerate ["f"] @> ground_eval ()]
