(** 4.5 Format-level operations *)

(* It's always ok to get minPositiveOf *)
theorem internal_minPositiveOf_ok (f : Format.t) =
  Result.is_ok ((Float.internal_minPositiveOf f) [@trigger])
  [@@disable Util.pow2, Util.ipow2]
  [@@by auto]
  [@@fc]

(* The result of minPositiveOf is never negative, zero, or NaN (but it can be +oo) *)
theorem minPositiveOf_positive (f : Format.t) =
  let open Float in
  let r = minPositiveOf f in
  not (isSignMinus f r) && not (isZero f r) && not (is_nan f r)
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]

(* The result of minNormalOf is normal, with some exceptions *)
theorem minNormalOf_normal (f : Format.t) =
  let open Float in
  let k = bitwidthOf f in
  let p = precisionOf f in
  let s = signednessOf f in
  let d = domainOf f in
  (s = Signedness.Unsigned || p < k) ==>
  match k, p, s, d with
  | 2, 1, Signed, Extended -> minNormalOf f = (nan f)
  | 2, 2, Unsigned, Extended -> minNormalOf f = (nan f)
  | _ -> isNormal f (minNormalOf f)
  [@@disable Util.pow2, Util.ipow2]
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]

