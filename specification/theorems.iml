  Result.is_ok (Float.internal_log2 f_x f_r rho x)
  [@@disable Float.wProject, Float.wDecode, Log.log2, Log.log, Log.ln]
  [@@timeout 60]
  [@@by auto]


(** 4.x.x Hypotenuse *)

(* wHypot wants a few helpers *)
theorem wHypot_h1 (x : real) =
  ((Util.ripow (Real.abs x) 2) [@trigger]) >=. 0.0
  [@@timeout 10]
  [@@by auto]
  [@@fc]

theorem wHypot_h2 (x : real) (y : real) =
  x >=. 0.0 && y >=. 0.0 ==> x +. y >=. 0.0
  [@@timeout 10]
  [@@by auto]
  [@@fc]

theorem wHypot_h3 (x : real) (y : real) =
  (((Util.ripow (Real.abs x) 2) +. (Util.ripow (Real.abs y) 2)) [@trigger]) >=. 0.0
  [@@timeout 10]
  [@@by auto]
  [@@fc]

(** [wHypot] never returns an error *)
theorem wHypot_ok (x : CER.t) (y : CER.t) =
  Result.is_ok (Float.wHypot x y)
  [@@timeout 60]
  [@@disable Sqrt.sqrt]
  [@@by auto]

(** [hypot] never returns an error *)
theorem internal_hypot_ok (f_x : Format.t) (f_y : Format.t) (f_r : Format.t) (rho : Projection.t) (x : Float.t) (y : Float.t) =
  Result.is_ok (Float.internal_hypot f_x f_y f_r rho x y)
  [@@disable Float.wProject, Float.wDecode, Float.wRoundToPrecision, Float.wSaturate, Util.pow2, Util.ipow2, Float.wHypot]
  [@@by [%use wHypot_ok (Float.wDecode f_x x) (Float.wDecode f_y y)] @> auto]

