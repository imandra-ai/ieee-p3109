(** [internal_tan] never returns an error *)
theorem sin_cos_never_zero (x : CER.t) (p : int) =
  let open Trigonometric in
  match x with
  | R x -> p > 0 ==> not (sin x p = 0.0 && cos x p = 0.0)
  | _ -> true
  [@@by [%use Trigonometric.sin_cos_never_zero (match CER.to_real x with Ok r -> r | Error _ -> 0.0) p] @> auto]

theorem wTan_ok (x : CER.t) =
  Result.is_ok (Float.wTan x)
  [@@disable Trigonometric.sin, Trigonometric.cos]
  [@@by [%use sin_cos_never_zero x (CERR.approx)] @> auto]

