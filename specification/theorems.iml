(** 4.10.4 Classifier operation *)

theorem predicate_coverage (f : Format.t) (x : Float.t) =
  Float.isNaN f x ||
  Float.isInfinite f x ||
  Float.isZero f x ||
  Float.isNormal f x ||
  Float.isSubnormal f x
  [@@timeout 3600]
  [@@by unroll_nonlin 600 10 250]
  [@@fc]

