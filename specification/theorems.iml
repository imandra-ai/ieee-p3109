[@@@import Util, "dune:math"]
[@@@import Log, "dune:math"]
[@@@import ErrorPropagation, "dune:basic"]
[@@@import Specification, "specification.iml"]
[@@@import Theorems_pow2, "theorems_pow2.iml"]
[@@@import Theorems_format_ranges, "theorems_format_ranges.iml"]
[@@@import Theorems_IEEE754, "theorems_ieee754.iml"]
[@@@import Theorems_BFloat16, "theorems_bfloat16.iml"]
[@@@import Theorems_exp, "theorems_exp.iml"]
[@@@import Theorems_projection, "theorems_projection.iml"]

open Specification
open ErrorPropagation

let unroll_nonlin qt nqt steps = Tactic.unroll ~smt:"z3-full-nonlinear" ~query_timeout:qt ~no_asm_query_timeout:nqt steps

(** Formats *)

theorem format_parameter_limits (f : Format.t) =
  let open Float in
  match f with
  | Internal _ ->
    let k = bitwidthOf f in
    let p = precisionOf f in
    let b = exponentBiasOf f in
    let s = signednessOf f in
    let d = domainOf f in
    0 < k && k <= 16 &&
    0 < p && p <= 16 &&
    b <= Util.ipow2 (k - p)
  | _ -> true
  [@@timeout 600]
  [@@by unroll_nonlin 20 10 100]

theorem m_hi_gt_0 (f : Format.t) =
  let open Float in
  let open Signedness in
  let open Domain in
  Format.is_internal f ==>
  let k = bitwidthOf f in
  let p = precisionOf f in
  let s = signednessOf f in
  let d = domainOf f in
  let m_hi = wDecode f (maxFiniteOf f) in
  (k = 2 && (p = 1 || p = 2) && s = Signed && d = Extended && m_hi = CER.zero) || CER.Infix.(m_hi > CER.zero)
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]


(** 4.6 Functions *)

theorem internal_wSaturate_ok (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t) (x : CER.t)  (s : Signedness.t) (d : Domain.t) =
  Result.is_ok (Float.internal_wSaturate m sat rnd x s d  [@trigger])
  [@@by auto]
  [@@fc]

theorem internal_wRoundToPrecision_ok (p : int) (b : int) (rnd : RoundingMode.t) (x : CER.t) =
  Result.is_ok (Float.internal_wRoundToPrecision p b rnd x)

theorem wDecodeAuxExternal_754_ok (f : IEEE754.Format.t) (x : Float.t) =
  Result.is_ok ((Float.wDecodeAuxExternal (Format.External.IEEE754 f) x) [@trigger])
  [@@by
    expand "Specification.Float.wDecodeAuxExternal" @>
    [%use Theorems_IEEE754.as_cer_ok f (IEEE754.of_int_repr f x)] @>
    unroll 0
  ]
  [@@fc]

theorem wDecodeAuxExternal_bf16_ok (x : Float.t) =
  Result.is_ok ((Float.wDecodeAuxExternal Format.External.BFloat16 x) [@trigger])
  [@@by
    expand "Specification.Float.wDecodeAuxExternal" @>
    [%use Theorems_BFloat16.as_cer_ok (BFloat16.of_int_repr x)] @>
    unroll 0
  ]
  [@@fc]

(* [wDecodeAux] external ok  *)
theorem wDecodeAux_external_ok (f : Format.t) (s: Signedness.t) (d : Domain.t) (x : Float.t) =
  Format.is_external f ==>
  Result.is_ok ((Float.wDecodeAux f s d x) [@trigger])
  [@@timeout 240]
  [@@disable Float.bitwidthOf, Float.precisionOf, Float.exponentBiasOf, IEEE754.as_cer, BFloat16.as_cer, IEEE754.to_binary_bits, IEEE754.of_int_repr, BFloat16.of_int_repr]
  [@@by
    expand "Specification.Float.wDecodeAux" @>
    expand "Specification.Format.is_external" @>
    intros @>
    simplify () @>| [
      [%use wDecodeAuxExternal_754_ok IEEE754.Format.Binary16 x] @>
      [%use wDecodeAuxExternal_754_ok IEEE754.Format.Binary32 x] @>
      [%use wDecodeAuxExternal_754_ok IEEE754.Format.Binary64 x] @>
      [%use wDecodeAuxExternal_754_ok IEEE754.Format.Binary128 x] @>
      unroll 0;
      [%use wDecodeAuxExternal_bf16_ok x] @>
      unroll 0
    ]
  ]
  [@@fc]

(* [wDecodeAux] internal ok  *)
theorem wDecodeAux_internal_ok (f : Format.t) (s: Signedness.t) (d : Domain.t) (x : Float.t) =
  Format.is_internal f ==>
  Result.is_ok ((Float.wDecodeAux f s d x) [@trigger])
  [@@timeout 600]
  [@@disable Float.bitwidthOf, Float.precisionOf, Float.exponentBiasOf, IEEE754.as_cer, BFloat16.as_cer, IEEE754.to_binary_bits, IEEE754.of_int_repr, BFloat16.of_int_repr]
  [@@by induct ~do_not:["gen"; "fert"; "delim"] ()]
  [@@fc]


(* [wDecodeAux] never throws an error *)
theorem wDecodeAux_ok (f : Format.t) (s: Signedness.t) (d : Domain.t) (x : Float.t) =
  Result.is_ok ((Float.wDecodeAux f s d x) [@trigger])
  [@@disable Float.bitwidthOf, Float.precisionOf, Float.exponentBiasOf, IEEE754.as_cer, BFloat16.as_cer, IEEE754.to_binary_bits, IEEE754.of_int_repr, BFloat16.of_int_repr]
  [@@by
    [%use wDecodeAux_external_ok f s d x] @>
    [%use wDecodeAux_internal_ok f s d x] @>
    unroll 0
  ]
  [@@fc]

(* [wDecode] always produces numbers within the format range *)
theorem decode_within_range (f : Format.t) (x : Float.t) =
  Format.is_internal f ==>
  Float.is_within_range f ((Float.wDecode f x) [@trigger])
  [@@timeout 600]
  [@@disable Float.wDecode, Float.maxFiniteOf]
  [@@by [%use Theorems_format_ranges.within_format_range f x] @> auto]
  [@@fc]

theorem wEncode_ok_within_datum_set_external (f : Format.t) (x : CER.t) =
  Format.is_external f ==>
  let encoded = ((Float.wEncode f x) [@trigger]) in
  if Float.is_in_datum_set f x then
    Result.is_ok encoded
  else
    Result.is_error encoded
  [@@timeout 60]
  [@@by unroll_nonlin 10 2 100]
  [@@fc]

theorem if_false (c : bool) (t : 'a) (f : 'a) =
  c ==> (if not c then t else f) = f

theorem wEncode_ok_within_datum_set_internal_within (f : Format.t) (x : CER.t) =
  Format.is_internal f &&
  Float.is_in_datum_set f x
  ==> Result.is_ok (Float.wEncode f x)
  [@@timeout 120]
  [@@disable Util.pow2, Util.ipow2, Float.is_in_datum_set, Float.bitwidthOf, Float.precisionOf, Float.exponentBiasOf, Float.signednessOf, Float.of_int_repr, Util.floor_log2_abs]
  [@@by
    intros @>
    [%expand "Specification.Float.wEncode"] @>
    [%rewrite
      if_false
      (Float.is_in_datum_set f x)
      [? at (if _ then _ else (_ : (int, string) result)) index(2)]
      [? at (if _ then _ else (_ : (int, string) result)) index(1)]
    ] @>
    [%cases x = CER.NaN, x = CER.PInf, x = CER.NInf ] @>|
      [
        unroll 0;
        unroll 0;
        unroll 0;
        simplify () @>
        unroll_nonlin 10 10 100
      ]
    ]

theorem wEncode_ok_within_datum_set_internal (f : Format.t) (x : CER.t) =
  Format.is_internal f ==>
  let encoded = Float.wEncode f x in
  if Float.is_in_datum_set f x then
    Result.is_ok encoded
  else
    Result.is_error encoded
  [@@timeout 20]
  [@@disable Float.is_in_datum_set, Float.bitwidthOf, Float.precisionOf, Float.exponentBiasOf, Float.signednessOf, Float.of_int_repr, Util.floor_log2_abs, Float.of_int_repr, Float.wEncodeExternal]
  [@@by
    [%use wEncode_ok_within_datum_set_internal_within f x] @>
    auto
    ]

(* [wEncode] is ok if the input is within the format datum_set *)
theorem wEncode_ok_within_datum_set (f : Format.t) (x : CER.t) =
  let encoded = (Float.wEncode f x) [@trigger] in
  if Float.is_in_datum_set f x then
    Result.is_ok encoded
  else
    Result.is_error encoded
  [@@by
    [%use wEncode_ok_within_datum_set_external f x] @>
    [%use wEncode_ok_within_datum_set_internal f x] @>
    unroll 10]
  [@@timeout 60]
  [@@fc]

theorem maxFinite_geq_0 (f : Format.t) =
  let open CER.Infix in
  Float.wDecode f (Float.maxFiniteOf f) >= CER.R 0.0
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]

theorem maxFinite_is_finite (f : Format.t) =
  match Float.wDecode f (Float.maxFiniteOf f) with
  | CER.R _ -> true
  | _ -> false
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]

theorem minFinite_is_finite (f : Format.t) =
  match Float.wDecode f (Float.minFiniteOf f) with
  | CER.R _ -> true
  | _ -> false
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]

(* [saturate] always produces a number within the format range *)
theorem wSaturate_is_within_range (f : Format.t) (x : CER.t) (sat : SaturationMode.t) (rnd : RoundingMode.t) =
  match Float.wDecode f (Float.maxFiniteOf f) with
  | CER.R m ->
    let s = ((Float.wSaturate m sat rnd x (Float.signednessOf f) (Float.domainOf f)) [@trigger]) in
    Float.is_within_range f s
  | _ -> false
  [@@timeout 3600]
  [@@disable Float.wDecode, Float.maxFiniteOf, Util.ipow2, Util.pow2]
  [@@by
    [%use maxFinite_is_finite f] @>
    [%use maxFinite_geq_0 f] @>
    (* auto *)
    induct ~do_not:["gen"; "fert"; "delim"] ()
    ]
  [@@fc]


(** [project] never returns an error *)
theorem wProject_ok (f : Format.t) (rho : Projection.t) (x : CER.t) =
  Result.is_ok ((Float.wProject f rho x) [@trigger])
  [@@timeout 3600]
  [@@disable Util.pow2, Util.ipow2, Util.floor_log2_abs, Float.signednessOf, Float.domainOf, Float.satOf, Float.wDecode, Float.wRoundToPrecision, Float.wSaturate, Float.maxFiniteOf, Float.wSaturate, Float.wRoundToPrecision]
  [@@by
    [%use maxFinite_is_finite f] @>
    [%use maxFinite_geq_0 f] @>
    [%use wEncode_ok_within_datum_set f (Theorems_projection.rnd_sat f rho x)] @>
    [%use Theorems_projection.rnd_sat_is_in_datum_set f rho x] @>
    [%expand "Theorems_projection.rnd_sat"] @>
    [%expand "Specification.Float.wProject"] @>
    unroll 0
    ]
  [@@fc]


(** Some helpers *)

theorem is_pinf_eq_decodes_to_pinf_internal (f : Format.t) (x : Float.t) =
  let open CER in
  Format.is_internal f ==>
  (Float.is_pinf f x <==> ((Float.wDecode f x = PInf) [@trigger]))
  [@@timeout 120]
  [@@by unroll 50]

theorem is_pinf_eq_decodes_to_pinf_bf16 (f : Format.t) (x : Float.t) =
  let open CER in
  match f with
  | External BFloat16 ->
    (Float.is_pinf f x <==> ((Float.wDecode f x = PInf) [@trigger]))
  | _ -> true
  [@@timeout 60]
  [@@by unroll 50]

theorem is_pinf_eq_decodes_to_pinf_754 (f : Format.t) (x : Float.t) =
  let open CER in
  match f with
  | External IEEE754 phi ->
    (IEEE754.is_pinf phi (IEEE754.of_int_repr phi x) <==> IEEE754.as_cer phi (IEEE754.of_int_repr phi x) = Ok PInf)
  | _ -> true
  [@@by
    [%use
      Theorems_IEEE754.is_pinf_eq_cer_pinf
      [? at ((_ : IEEE754.Format.t))]
      (IEEE754.of_int_repr [? at ((_ : IEEE754.Format.t))] x)] @>
    unroll 0]

theorem is_pinf_eq_decodes_to_pinf_external (f : Format.t) (x : Float.t) =
  let open CER in
  Format.is_external f ==>
  (Float.is_pinf f x <==> ((Float.wDecode f x = PInf) [@trigger]))
  [@@by
    [%use is_pinf_eq_decodes_to_pinf_bf16 f x] @>
    [%use is_pinf_eq_decodes_to_pinf_754 f x] @>
    unroll 2]

theorem is_pinf_eq_decodes_to_pinf (f : Format.t) (x : Float.t) =
  let open CER in
  Float.is_pinf f x <==> ((Float.wDecode f x = PInf) [@trigger])
  [@@timeout 3600]
  [@@by
    [%use is_pinf_eq_decodes_to_pinf_internal f x] @>
    [%use is_pinf_eq_decodes_to_pinf_external f x] @>
    unroll 0]
  [@@fc]

theorem is_ninf_eq_decodes_to_ninf_internal (f : Format.t) (x : Float.t) =
  let open CER in
  Format.is_internal f ==>
  (Float.is_ninf f x <==> ((Float.wDecode f x = NInf) [@trigger]))
  [@@timeout 3600]
  [@@by unroll_nonlin 10 10 100]

theorem is_ninf_eq_decodes_to_ninf_bf16 (f : Format.t) (x : Float.t) =
  let open CER in
  match f with
  | External BFloat16 ->
    (Float.is_ninf f x <==> ((Float.wDecode f x = NInf) [@trigger]))
  | _ -> true
  [@@timeout 60]
  [@@by unroll 50]

theorem is_ninf_eq_decodes_to_ninf_754 (f : Format.t) (x : Float.t) =
  let open CER in
  match f with
  | External IEEE754 phi ->
    (IEEE754.is_ninf phi (IEEE754.of_int_repr phi x) <==> IEEE754.as_cer phi (IEEE754.of_int_repr phi x) = Ok NInf)
  | _ -> true
  [@@timeout 3600]
  [@@by
    [%use
      Theorems_IEEE754.is_ninf_eq_cer_ninf
      [? at ((_ : IEEE754.Format.t))]
      (IEEE754.of_int_repr [? at ((_ : IEEE754.Format.t))] x)] @>
    unroll 0]

theorem is_ninf_eq_decodes_to_ninf_external (f : Format.t) (x : Float.t) =
  let open CER in
  Format.is_external f ==>
  (Float.is_ninf f x <==> ((Float.wDecode f x = NInf) [@trigger]))
  [@@by
    [%use is_ninf_eq_decodes_to_ninf_bf16 f x] @>
    [%use is_ninf_eq_decodes_to_ninf_754 f x] @>
    unroll 2]

theorem is_ninf_eq_decodes_to_ninf (f : Format.t) (x : Float.t) =
  let open CER in
  Float.is_ninf f x <==> ((Float.wDecode f x = NInf) [@trigger])
  [@@by
    [%use is_ninf_eq_decodes_to_ninf_internal f x] @>
    [%use is_ninf_eq_decodes_to_ninf_external f x] @>
    unroll 0]
  [@@fc]

theorem is_inf_eq_decodes_to_inf (f : Format.t) (x : Float.t) =
  let open CER in
  ((Float.is_inf f x) [@trigger]) <==> (Float.wDecode f x = NInf || Float.wDecode f x = PInf)
  [@@by
    [%use is_pinf_eq_decodes_to_pinf f x] @>
    [%use is_ninf_eq_decodes_to_ninf f x] @>
    unroll 1]
  [@@fc]

theorem is_nan_eq_decodes_to_nan (f : Format.t) (x : Float.t) =
  let open CER in
  Float.is_nan f x <==> ((Float.wDecode f x = NaN) [@trigger])
  [@@timeout 3600]
  [@@by unroll 5000]
  [@@fc]

theorem is_zero_eq_decodes_to_zero (f : Format.t) (x : Float.t) =
  let open CER in
  Float.isZero f x <==> (Float.wDecode f x = R 0.0) [@trigger]
  [@@by unroll 25]
  [@@fc]

theorem ipow2_gt_0 (n:int) =
  (Util.ipow2 n) [@trigger] > 0
  [@@timeout 10]
  [@@by auto]
  [@@fc]

theorem decode_0_is_0 (f : Format.t)  =
  let open CER in
  (Float.wDecode f 0) [@trigger] = R 0.0
  [@@timeout 60]
  [@@by enumerate ["f"] @> ground_eval ()]
  [@@fc]

theorem zero_means_is_zero (f : Format.t) (x : Float.t) =
  let open CER in
  x = 0 ==> ((Float.isZero f x) [@trigger])
  [@@by [%use decode_0_is_0 f] @> unroll 0]
  [@@fc]

(** 5.11 Converting between formats *)

(** [convert] never returns an error *)
theorem convert_ok (f_x : Format.t) (f_r : Format.t) (rho : Projection.t) (x : Float.t) =
  Result.is_ok (Float.convert f_x f_r rho x)
  [@@disable Float.wProject, Float.wDecode, Util.pow2, Util.ipow2]
  [@@by auto]


