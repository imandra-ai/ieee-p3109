(* Some extras *)

theorem wExp_is_positive (x : CER.t) =
  let open CER in
  match Float.wExp x with
  | Ok CER.NaN -> true
  | Ok CER.PInf -> true
  | Ok CER.NInf -> false
  | Ok (R x) -> x >=. 0.0
  | Error _ -> false
  [@@timeout 3600]
  [@@disable Util.pow2, Util.ipow2, Util.ripow, Exp.exp]
  [@@by auto]

theorem wSaturate_preserves_positivity (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t) (x : CER.t) (s : Signedness.t) (d : Domain.t) =
  let open CER.Infix in
  m >. 0.0 && d = Domain.Extended ==>
  x >= CER.zero ==> (Float.wSaturate m sat rnd x s d) [@trigger] >= CER.zero
  [@@disable Float.wDecode, Float.maxFiniteOf, Util.pow2, Util.ipow2, Util.floor_log2_abs, Util.floor, Util.ifloor]
  [@@by auto]
  [@@fc]

theorem sub_is_add_neg (x : CER.t) (y : CER.t) =
  match (Float.wNegate y)
  with Ok ny ->
    Float.wSubtract x y = Float.wAdd x ny
  | _ -> false

theorem fma_is_mul_add (x : CER.t) (y : CER.t) (z : CER.t) =
  match (Float.wMultiply x y) with
  | Ok xy ->
    Float.wFMA x y z = Float.wAdd xy z
  | _ -> false

theorem faa_is_add_add (x : CER.t) (y : CER.t) (z : CER.t) =
  match (Float.wAdd x y) with
  | Ok xpy ->
    Float.wFAA x y z = Float.wAdd xpy z
  | _ -> false

theorem faa_is_add_add' (x : CER.t) (y : CER.t) (z : CER.t) =
  match (Float.wAdd y z) with
  | Ok ypz ->
    Float.wFAA x y z = Float.wAdd x ypz
  | _ -> false

theorem add_commutes (x : CER.t) (y : CER.t) =
  Float.wAdd x y = Float.wAdd y x

theorem mul_commutes (x : CER.t) (y : CER.t) =
  Float.wMultiply x y = Float.wMultiply y x

theorem add_associates (x : CER.t) (y : CER.t) (z : CER.t)=
  match Float.wAdd x y, Float.wAdd y z with
  | Ok xpy, Ok ypz ->
    Float.wAdd (xpy) z = Float.wAdd x (ypz)
  | _ -> false

theorem mul_associates (x : CER.t) (y : CER.t) (z : CER.t)=
  match Float.wMultiply x y, Float.wMultiply y z with
  | Ok xy, Ok yz ->
    Float.wMultiply (xy) z = Float.wMultiply x (yz)
  | _ -> false
  [@@by auto]

(* Saturation is idempotent *)
theorem idem_saturate (m : real) (sat : SaturationMode.t) (rnd : RoundingMode.t) (x : CER.t) (s : Signedness.t) (d : Domain.t) =
  m >. 0.0 ==>
  Float.wSaturate m sat rnd x s d = Float.wSaturate m sat rnd (Float.wSaturate m sat rnd x s d) s d
  [@@disable Util.pow2, Util.ipow2, Util.floor_log2_abs, Util.floor, Util.ifloor, Log.ln, Exp.exp]
  [@@by auto]

theorem every_format_has_a_one (f : Format.t) =
  Float.bitwidthOf f >= 3 (* k=2 is technically not in spec, but does have cases without 1.0 *) ==>
  match Float.wProject f (SaturationMode.SatNone, RoundingMode.NearestTiesToEven) (CER.R 1.0) with
  | Ok x -> Float.wDecode f x = (CER.R 1.0)
  | _ -> false
  [@@by enumerate ["f"] @> ground_eval ()]
