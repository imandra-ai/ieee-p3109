[@@@import Util, "dune:math"]
[@@@import IEEE754, "IEEE754.iml"]

open IEEE754

[@@@import Theorems_pow2, "theorems_pow2.iml"]

let unroll_nonlin qt nqt steps = Tactic.unroll ~smt:"z3-full-nonlinear" ~query_timeout:qt ~no_asm_query_timeout:nqt steps

theorem as_cer_ok (phi : Format.t) (x : t) =
  Result.is_ok (as_cer phi x)
  [@@disable Util.pow2, Util.ipow2]
  [@@by auto]

theorem nan_is_not_pinf (phi : Format.t) (x : t) =
  is_nan phi x ==> not (is_pinf phi x)
  [@@timeout 60]
  [@@disable Util.pow2, Util.ipow2]
  [@@by auto]

theorem nan_is_not_ninf (phi : Format.t) (x : t) =
  is_nan phi x ==> not (is_ninf phi x)
  [@@timeout 60]
  [@@disable Util.pow2, Util.ipow2]
  [@@by auto]

theorem is_pinf_eq_cer_pinf_fwd (phi : Format.t) (x : t) =
  let open CER in
  is_pinf phi x ==> as_cer phi x = Ok PInf
  [@@by
    [%use nan_is_not_pinf phi x] @>
    expand "IEEE754.as_cer" @>
    unroll 0]

theorem is_pinf_neq_pinf (phi : Format.t) (x : t) =
  let open CER in
  is_pinf phi x <==> x = (pinf phi)
  [@@by
    expand "IEEE754.is_pinf" @>
    unroll 0]

theorem not_pinf_means_not_eq phi x =
  not (is_pinf phi x) ==> x <> IEEE754.pinf phi

theorem is_pinf_eq_cer_pinf_bwd (phi : Format.t) (x : t) =
  let open CER in
  as_cer phi x = Ok PInf ==> is_pinf phi x
  [@@by unroll 0]

theorem is_pinf_eq_cer_pinf (phi : Format.t) (x : t) =
  let open CER in
  is_pinf phi x <==> as_cer phi x = Ok PInf
  [@@timeout 60]
  [@@by
    [%use is_pinf_eq_cer_pinf_fwd phi x] @>
    [%use is_pinf_eq_cer_pinf_bwd phi x] @>
    unroll 0]

theorem is_ninf_eq_cer_ninf_bwd (phi : Format.t) (x : t) =
  let open CER in
  as_cer phi x = Ok NInf ==> is_ninf phi x
  [@@timeout 60]
  [@@disable Util.pow2, Util.ipow2, Format.parameters]
  [@@by unroll 0]

theorem is_ninf_eq_cer_ninf_fwd (phi : Format.t) (x : t) =
  let open CER in
  is_ninf phi x ==> as_cer phi x = Ok NInf
  [@@timeout 60]
  [@@by
    [%use nan_is_not_ninf phi x] @>
    expand "IEEE754.as_cer" @>
    unroll 10]

theorem is_ninf_eq_cer_ninf (phi : Format.t) (x : t) =
  let open CER in
  is_ninf phi x <==> as_cer phi x = Ok NInf
  [@@timeout 60]
  [@@by
    [%use is_ninf_eq_cer_ninf_fwd phi x] @>
    [%use is_ninf_eq_cer_ninf_bwd phi x] @>
    unroll 0]